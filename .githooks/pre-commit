#!/usr/bin/env bash
set -euo pipefail

# Block likely secrets in newly added staged lines (exclude this hook file to avoid self-matches)
# NOTE: detect credential-like assignments, not mere env var names.
patch=$(git diff --cached -U0 -- . ':(exclude).githooks/pre-commit' || true)
if [ -n "${patch}" ]; then
  if echo "${patch}" | grep -nE "^\+.*(BEGIN (RSA|EC|OPENSSH|PGP) PRIVATE KEY|AKIA[0-9A-Z]{16}|ghp_[A-Za-z0-9]{20,}|xox[baprs]-[A-Za-z0-9-]{20,})"; then
    echo "❌ Possible secret detected in staged additions (key/token pattern)."
    exit 1
  fi

  if echo "${patch}" | grep -nE "^\+.*(TG_BOT_TOKEN|X_BEARER_TOKEN|OPENCLAW_GATEWAY_TOKEN|GEMINI_API_KEY|API_KEY)\s*[:=]\s*['\"][^'\"]{12,}['\"]"; then
    echo "❌ Possible secret detected: token/api key literal assignment in staged additions."
    exit 1
  fi
fi

# Basic python syntax check for staged .py files
files=$(git diff --cached --name-only | grep -E '\.py$' || true)
if [ -n "${files}" ]; then
  python3 -m py_compile ${files}
fi
